      { "name": "memorias-ram", "url": "https://www.memorykings.pe/subcategorias/20/memorias-ram" },
      { "name": "placas-madre", "url": "https://www.memorykings.pe/subcategorias/27/placas-madre" },
      { "name": "discos-internos", "url": "https://www.memorykings.pe/subcategorias/57/discos-duro-almacenamiento-interno" },
      { "name": "case-fuentes", "url": "https://www.memorykings.pe/subcategorias/29/case-fuentes" },
      { "name": "monitores", "url": "https://www.memorykings.pe/subcategorias/31/monitores-pantallas" },
      { "name": "pcs-desktop", "url": "https://www.memorykings.pe/subcategorias/11/pcs-desktop-de-marca" }
    ],
    "sampleProductUrl": "https://www.memorykings.pe/producto/355762/laptop-ryzen-7-170-asus-tuf-gaming-a15-fa506ncq",
    "pagination": {
      "type": "link",
      "nextSelector": "a[rel='next'], a.siguiente, .pagination a.next",
      "start": 1
    },
    "listing": {
      "productLinkSelector": "a[href*='/producto/']",
      "waitMs": 2500,
      "maxPages": 20
    },
    "product": {
      "name": "h1",
      "price": ".price.pt-1, .price",
      "priceCurrencyHint": "S/",
      "image": "meta[property='og:image'], img[src*='cdn.memorykings.pe/files']",
      "specs": "table"
    }
  },
  "sercoplus": {
    "baseUrl": "https://sercoplus.com",
    "platform": "unknown",
    "status": "blocked_cloudflare",
    "notes": "Al 2026-07-23 responde challenge Cloudflare (403/JS challenge). Selectores pendientes de validación manual con browser real o allowlist. No scrapear en CI hasta resolver anti-bot.",
    "categories": [],
    "sampleProductUrl": null,
    "pagination": {
      "type": "unknown",
      "param": "page",
      "start": 1
    },
    "listing": {
      "productLinkSelector": "a[href*='producto'], a[href*='product']",
      "maxPages": 10
    },
    "product": {
      "name": "h1",
      "price": ".price, [class*='price'], [class*='precio']",
      "image": "meta[property='og:image']",
      "specs": "table, .specs, .product-attributes"
    },
    "antiBot": {
      "cloudflare": true,
      "requiresPlaywrightStealth": true
    }
  },
  "impacto": {
