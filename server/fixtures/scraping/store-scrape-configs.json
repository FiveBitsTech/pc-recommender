{
  "memory-kings": {
    "baseUrl": "https://www.memorykings.pe",
    "platform": "custom-php",
    "notes": "Listados por /listados/{id}/... cargan mejor que algunas subcategorías. Productos en /producto/{id}/{slug}.",
    "categories": [
      { "name": "laptops", "url": "https://www.memorykings.pe/subcategorias/19/laptops" },
      { "name": "laptops-ryzen-7", "url": "https://www.memorykings.pe/listados/388/laptops-ryzen-7" },
