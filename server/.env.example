# =============================================================================
# ÚNICO archivo de entorno para local / Nest / Prisma
# Copia:  cp .env.example .env   y completa secretos
# =============================================================================
NODE_ENV=development
PORT=5300
TZ=America/Lima

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

CORS_ORIGIN=http://localhost:3000

SCRAPE_MODE=live
SCRAPE_CRON=0 3 * * *
SCRAPE_CRON_ENABLED=false
SCRAPE_SOURCES=cyccomputer,impacto,deltron,memory-kings
SCRAPE_PREVIEW_LIMIT=5
SCRAPE_PRODUCT_LIMIT=150
SCRAPE_CATEGORY_PAGES=15
CYCCOMPUTER_BASE_URL=https://cyccomputer.pe/
IMPACTO_BASE_URL=https://www.impacto.com.pe/
DELTRON_BASE_URL=https://www.deltron.com.pe/
MEMORY_KINGS_BASE_URL=https://memorykings.pe/

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@pc-cotiza.local
ADMIN_PASSWORD=change_me

OPENAI_API_KEY=

# Prisma (equipo) — no uses "npx prisma db pull" a pelo:
#   pnpm prisma:pull       # pull seguro (evita @@ignore / schema roto)
#   pnpm prisma:repair-db  # repara PKs/FKs si la BD está incompleta
