# =============================================================================
# ÚNICO archivo de entorno para local / Nest / Prisma
# Copia:  cp .env.example .env   y completa secretos
# =============================================================================
NODE_ENV=development
PORT=5300
TZ=America/Lima

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

CORS_ORIGIN=http://localhost:3000

# Scraping vía empresas (UI: dominio + scrapeConfig IA)
SCRAPE_PRODUCT_LIMIT=2000
SCRAPE_REQUEST_DELAY_MS=400
SCRAPE_CRON=0 3 * * *
SCRAPE_CRON_ENABLED=false

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@pc-cotiza.local
ADMIN_PASSWORD=change_me

OPENAI_API_KEY=
