NODE_ENV=development
PORT=5300
TZ=America/Lima

# PostgreSQL — ajusta host, puerto, usuario, password y nombre de BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/pc_recommender?schema=public"

# CORS (origen del client Next)
CORS_ORIGIN=http://localhost:3000

# Scraping
SCRAPE_MODE=fixture
SCRAPE_CRON=0 3 * * *
SCRAPE_CRON_ENABLED=true
SCRAPE_SOURCES=fixture
SCRAPE_PREVIEW_LIMIT=5
CYCCOMPUTER_BASE_URL=https://cyccomputer.pe/
IMPACTO_BASE_URL=https://www.impacto.com.pe/
DELTRON_BASE_URL=https://www.deltron.com.pe/
# MEMORY_KINGS_LISTING_URL=
# MEMORY_KINGS_PRODUCT_URLS=

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@pc-cotiza.local
ADMIN_PASSWORD=Admin123!
