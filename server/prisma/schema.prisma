generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash")
  name         String?    @db.VarChar(255)
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Company {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(255)
  website         String?           @db.VarChar(500)
  logoUrl         String?           @map("logo_url") @db.VarChar(500)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  slug            String            @unique @db.VarChar(100)
  scrapeConfig    Json?             @map("scrape_config")
  products        Product[]
  scrapingHistory ScrapingHistory[]

  @@map("companies")
}

model Product {
  id               Int                  @id @default(autoincrement())
  companyId        Int                  @map("company_id")
  name             String               @db.VarChar(255)
  brand            String?              @db.VarChar(100)
  model            String?              @db.VarChar(100)
  category         String?              @db.VarChar(100)
  productUrl       String?              @map("product_url") @db.VarChar(1000)
  imageUrl         String?              @map("image_url") @db.VarChar(1000)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  externalSku      String?              @map("external_sku") @db.VarChar(100)
  comparisonsAsOne ProductComparison[]  @relation("ProductOne")
  comparisonsAsTwo ProductComparison[]  @relation("ProductTwo")
  prices           ProductPrice[]
  specs            ProductSpec?
  tagRelations     ProductTagRelation[]
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recommendations  Recommendation[]

  @@unique([companyId, productUrl])
  @@index([companyId])
  @@index([category])
  @@map("products")
}

model ProductSpec {
  id              Int     @id @default(autoincrement())
  productId       Int     @unique @map("product_id")
  processor       String? @db.VarChar(255)
  gpu             String? @db.VarChar(255)
  ram             String? @db.VarChar(100)
  storage         String? @db.VarChar(100)
  screen          String? @db.VarChar(100)
  operatingSystem String? @map("operating_system") @db.VarChar(100)
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

model ProductPrice {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  price     Decimal  @db.Decimal(12, 2)
  currency  String   @default("PEN") @db.VarChar(10)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  available Boolean  @default(true)
  stockQty  Int?     @map("stock_qty")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_prices")
}

model ProductTag {
  id        Int                  @id @default(autoincrement())
  name      String               @unique @db.VarChar(100)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  relations ProductTagRelation[]

  @@map("product_tags")
}

model ProductTagRelation {
  id        Int        @id @default(autoincrement())
  productId Int        @map("product_id")
  tagId     Int        @map("tag_id")
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([tagId])
  @@map("product_tag_relations")
}

model UserRequirement {
  id              Int              @id @default(autoincrement())
  usageType       String           @map("usage_type") @db.VarChar(100)
  budget          Decimal          @db.Decimal(12, 2)
  priority        String           @db.VarChar(100)
  deviceType      String           @map("device_type") @db.VarChar(100)
  brandPreference String?          @map("brand_preference") @db.VarChar(50)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  recommendations Recommendation[]

  @@map("user_requirements")
}

model Recommendation {
  id            Int             @id @default(autoincrement())
  requirementId Int             @map("requirement_id")
  productId     Int             @map("product_id")
  score         Decimal         @db.Decimal(8, 4)
  reason        String?
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  requirement   UserRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([productId])
  @@map("recommendations")
}

model ProductComparison {
  id           Int      @id @default(autoincrement())
  productOneId Int      @map("product_one_id")
  productTwoId Int      @map("product_two_id")
  analysis     String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  productOne   Product  @relation("ProductOne", fields: [productOneId], references: [id], onDelete: Cascade)
  productTwo   Product  @relation("ProductTwo", fields: [productTwoId], references: [id], onDelete: Cascade)

  @@index([productOneId])
  @@index([productTwoId])
  @@map("product_comparisons")
}

model ScrapingHistory {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  status        String   @db.VarChar(50)
  productsFound Int      @default(0) @map("products_found")
  executedAt    DateTime @default(now()) @map("executed_at") @db.Timestamptz(6)
  source        String   @db.VarChar(100)
  errorMessage  String?  @map("error_message")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([source])
  @@map("scraping_history")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}
